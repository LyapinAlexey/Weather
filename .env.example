# WeatherAPI.com key — get yours at https://www.weatherapi.com/
WEATHER_API_KEY=
LOG_LEVEL=INFO

# Data base
DATABASE_URL=postgresql://your_user:your_password@weather_db:5432/your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db

# Tests
POSTGRES_TEST_USER=test_user
POSTGRES_TEST_PASSWORD=test_password
POSTGRES_TEST_DB=test_weather_db
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5433/test_weather_db

# Port of Flask
FLASK_PORT=5001

# Debug mode
FLASK_DEBUG=False

# Secret key for session protection — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
